{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "stream",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "src/**/*.ts"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "persistent": true,
            "interruptible": true,
            "cache": false
        },
        "start": {
            "dependsOn": [
                "build"
            ],
            "persistent": true,
            "interruptible": true,
            "cache": false
        }
    }
}